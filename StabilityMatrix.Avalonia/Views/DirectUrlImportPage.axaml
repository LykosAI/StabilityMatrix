<controls:UserControlBase
    x:Class="StabilityMatrix.Avalonia.Views.DirectUrlImportPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:checkpointBrowser="clr-namespace:StabilityMatrix.Avalonia.ViewModels.CheckpointBrowser"
    xmlns:controls="clr-namespace:StabilityMatrix.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="clr-namespace:StabilityMatrix.Avalonia.Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mocks="clr-namespace:StabilityMatrix.Avalonia.DesignData"
    d:DataContext="{x:Static mocks:DesignData.HuggingFacePageViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="800"
    x:CompileBindings="True"
    x:DataType="checkpointBrowser:DirectUrlImportViewModel"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16" VerticalAlignment="Top">
            <!-- Header -->
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Text="Direct URL Import" />

            <!-- URLs Input Section -->
            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="Medium"
                    Text="Input URLs (one per line):" />

                <TextBox
                    AcceptsReturn="True"
                    Height="150"
                    IsEnabled="{Binding !IsImporting}"
                    Watermark="https://example.com/model.safetensors&#10;https://civitai.com/models?query=anime"
                    Text="{Binding UrlsInput, Mode=TwoWay}"
                    TextWrapping="Wrap"
                    VerticalAlignment="Top" />
            </StackPanel>

            <!-- Filename Section -->
            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="Medium"
                    Text="Model Filename (for direct URLs):" />

                <TextBox
                    IsEnabled="{Binding !IsImporting}"
                    Watermark="model.safetensors"
                    Text="{Binding ModelFileName, Mode=TwoWay}" />
            </StackPanel>

            <!-- Download Location Section -->
            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="Medium"
                    Text="Download Location:" />

                <StackPanel Spacing="8" Orientation="Horizontal">
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        IsEnabled="{Binding !IsImporting}"
                        ItemsSource="{Binding AvailableDownloadLocations}"
                        SelectedItem="{Binding SelectedDownloadLocation}"
                        Width="300" />

                    <Button
                        Classes="transparent-full"
                        Command="{Binding SelectCustomFolderCommand}"
                        Content="Browse..." />
                </StackPanel>

                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    IsVisible="{Binding !!CustomDownloadLocation}"
                    Text="{Binding CustomDownloadLocation}" />
            </StackPanel>

            <!-- Status Section -->
            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    IsVisible="{Binding !!ImportStatus}"
                    Text="{Binding ImportStatus}" />
            </StackPanel>

            <!-- Standard start button -->
            <StackPanel Spacing="8" Orientation="Horizontal" IsVisible="{Binding !IsCivitAiSelectionMode}">
                <Button
                    Classes="accent"
                    Command="{Binding ImportCommand}"
                    IsEnabled="{Binding !IsImporting}"
                    Content="Start Download" />
            </StackPanel>

            <!-- CivitAI paging/selection section -->
            <Border
                Background="{DynamicResource ColorNeutralBackground3}"
                BorderBrush="{DynamicResource ColorNeutralStroke2}"
                BorderThickness="1"
                CornerRadius="6"
                IsVisible="{Binding IsCivitAiSelectionMode}"
                Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Select CivitAI models from current page" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding CivitAiCurrentPageLabel}" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding CivitAiCurrentPageUrl}" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        IsVisible="{Binding !!CivitAiSelectionStatus}"
                        Text="{Binding CivitAiSelectionStatus}" />

                    <ListBox
                        ItemsSource="{Binding CivitAiCurrentPageModels}"
                        MaxHeight="280">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox
                                    IsChecked="{Binding IsSelected}"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Stretch">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}" TextWrapping="NoWrap" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Text="{Binding Details}" TextWrapping="NoWrap" />
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Spacing="8" Orientation="Horizontal">
                        <Button
                            Classes="accent"
                            Command="{Binding ImportSelectedCivitAiModelsCommand}"
                            IsEnabled="{Binding !IsImporting}"
                            Content="Import selected from this page" />

                        <Button
                            Command="{Binding SkipCurrentCivitAiPageCommand}"
                            IsEnabled="{Binding !IsImporting}"
                            Content="Skip this page" />

                        <Button
                            Command="{Binding ContinueNextCivitAiPageCommand}"
                            IsEnabled="{Binding !IsImporting}"
                            IsVisible="{Binding HasMoreCivitAiPages}"
                            Content="Load next page" />

                        <Button
                            Command="{Binding CancelCivitAiSelectionCommand}"
                            Content="Cancel" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Info Section -->
            <Border
                Padding="12"
                Background="{DynamicResource ColorNeutralBackground3}"
                BorderBrush="{DynamicResource ColorNeutralStroke2}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Text="Tips:" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="• If you add CivitAI page URLs (for example https://civitai.com/models?query=... ), you'll be asked to pick models page-by-page."
                        TextWrapping="Wrap" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="• Use direct URLs only when you want a single fallback filename for download."
                        TextWrapping="Wrap" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="• If your CivitAI URL is a model page (https://civitai.com/models/12345), the page's available models are shown for selection."
                        TextWrapping="Wrap" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="• The download will be saved to the selected model folder."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</controls:UserControlBase>
