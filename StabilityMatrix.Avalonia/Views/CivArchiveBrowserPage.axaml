<controls:UserControlBase
    x:Class="StabilityMatrix.Avalonia.Views.CivArchiveBrowserPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:checkpointBrowser="clr-namespace:StabilityMatrix.Avalonia.ViewModels.CheckpointBrowser"
    xmlns:checkpointManager="clr-namespace:StabilityMatrix.Avalonia.ViewModels.CheckpointManager"
    xmlns:civArchive="clr-namespace:StabilityMatrix.Core.Models.Api.CivArchive;assembly=StabilityMatrix.Core"
    xmlns:controls="clr-namespace:StabilityMatrix.Avalonia.Controls"
    xmlns:converters="clr-namespace:StabilityMatrix.Avalonia.Converters"
    xmlns:lang="clr-namespace:StabilityMatrix.Avalonia.Languages"
    xmlns:scroll="clr-namespace:StabilityMatrix.Avalonia.Controls.Scroll"
    xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    x:Name="Root"
    x:CompileBindings="True"
    x:DataType="checkpointBrowser:CivArchiveBrowserViewModel">

    <UserControl.Resources>
        <converters:KiloFormatterStringConverter x:Key="KiloFormatterConverter" />
        <DataTemplate x:Key="CivArchiveCardTemplate" DataType="{x:Type civArchive:CivArchiveSearchResult}">
            <Border
                Margin="8"
                ClipToBounds="True"
                CornerRadius="8">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuItem
                            Command="{Binding #Root.DataContext.OpenOnCivArchiveCommand}"
                            CommandParameter="{Binding .}"
                            Header="Open on CivArchive" />
                        <MenuItem
                            Command="{Binding #Root.DataContext.SearchByCreatorCommand}"
                            CommandParameter="{Binding .}"
                            Header="Browse creator" />
                        <MenuItem
                            Command="{Binding #Root.DataContext.CopySha256Command}"
                            CommandParameter="{Binding .}"
                            Header="Copy SHA256"
                            IsVisible="{Binding Sha256FromUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </MenuFlyout>
                </Border.ContextFlyout>
                <Button
                    Padding="0"
                    BorderThickness="0"
                    Classes="transparent-full"
                    Command="{Binding #Root.DataContext.OpenResultCommand}"
                    CommandParameter="{Binding .}"
                    CornerRadius="8">
                    <Grid Width="330" RowDefinitions="300, Auto">
                        <Grid>
                            <controls:BetterAdvancedImage
                                CornerRadius="8"
                                IsVisible="{Binding ImageUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Source="{Binding ImageUrl}"
                                Stretch="UniformToFill" />
                            <Border Background="#22000000" IsVisible="{Binding ImageUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="0.7"
                                    Text="No image" />
                            </Border>
                            <StackPanel
                                Margin="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Orientation="Horizontal"
                                Spacing="6">
                                <controls:Card Padding="6,2">
                                    <TextBlock FontSize="11" Text="{Binding KindRaw}" />
                                </controls:Card>
                                <controls:Card Padding="6,2">
                                    <TextBlock FontSize="11" Text="{Binding Type}" />
                                </controls:Card>
                                <controls:Card Padding="6,2" IsVisible="{Binding BaseModel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock FontSize="11" Text="{Binding BaseModel}" />
                                </controls:Card>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="#99000000">
                            <Grid Margin="10" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock
                                    MaxWidth="280"
                                    FontWeight="SemiBold"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,4,0,0"
                                    FontSize="12"
                                    Opacity="0.8"
                                    Text="{Binding Username}" />
                                <Grid
                                    Grid.Row="2"
                                    Margin="0,8,0,0"
                                    ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock FontSize="12" Text="{Binding Platform}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        FontSize="12"
                                        Text="{Binding DownloadCount, Converter={StaticResource KiloFormatterConverter}}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="8,0,0,0"
                                        FontSize="12"
                                        Text="{Binding CreatedAt, StringFormat={}{0:g}}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Button>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Margin="8" Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox
                    x:Name="SearchTextBox"
                    KeyDown="InputElement_OnKeyDown"
                    Text="{Binding SearchQuery, Mode=TwoWay}"
                    Watermark="Search by model name, filename, SHA256 hash, or CivArchive link" />
                <Button
                    Grid.Column="1"
                    Width="80"
                    Margin="8,0,0,0"
                    Classes="accent"
                    Command="{Binding SearchModelsCommand}"
                    CommandParameter="{StaticResource False}"
                    Content="Search" />
            </Grid>

            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,4,0"
                    Content="Platform" />
                <Label
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="4,0,4,0"
                    Content="{x:Static lang:Resources.Label_Sort}" />
                <Label
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="4,0,4,0"
                    Content="{x:Static lang:Resources.Label_TimePeriod}" />
                <Label
                    Grid.Row="0"
                    Grid.Column="3"
                    Margin="4,0,4,0"
                    Content="Kind" />
                <Label
                    Grid.Row="0"
                    Grid.Column="4"
                    Margin="4,0,4,0"
                    Content="Rating" />
                <Label
                    Grid.Row="0"
                    Grid.Column="5"
                    Margin="4,0,0,0"
                    Content="Status" />

                <ComboBox
                    Grid.Row="1"
                    Grid.Column="0"
                    MinWidth="120"
                    Margin="0,0,4,4"
                    ItemsSource="{Binding AllPlatforms}"
                    SelectedItem="{Binding SelectedPlatform}" />
                <ComboBox
                    Grid.Row="1"
                    Grid.Column="1"
                    MinWidth="100"
                    Margin="4,0,4,4"
                    ItemsSource="{Binding AllSorts}"
                    SelectedItem="{Binding SelectedSort}" />
                <ComboBox
                    Grid.Row="1"
                    Grid.Column="2"
                    MinWidth="80"
                    Margin="4,0,4,4"
                    ItemsSource="{Binding AllPeriods}"
                    SelectedItem="{Binding SelectedPeriod}" />
                <ComboBox
                    Grid.Row="1"
                    Grid.Column="3"
                    MinWidth="80"
                    Margin="4,0,4,4"
                    ItemsSource="{Binding AllKinds}"
                    SelectedItem="{Binding SelectedKind}" />
                <ComboBox
                    Grid.Row="1"
                    Grid.Column="4"
                    MinWidth="80"
                    Margin="4,0,4,4"
                    ItemsSource="{Binding AllRatings}"
                    SelectedItem="{Binding SelectedRating}" />
                <ComboBox
                    Grid.Row="1"
                    Grid.Column="5"
                    MinWidth="80"
                    Margin="4,0,0,4"
                    ItemsSource="{Binding AllPlatformStatuses}"
                    SelectedItem="{Binding SelectedPlatformStatus}" />

                <Label
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,4,4,0"
                    Content="Tags" />
                <Label
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="4,4,4,0"
                    Content="Username" />
                <Label
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="4,4,4,0"
                    Content="{x:Static lang:Resources.Label_ModelType}" />
                <Label
                    Grid.Row="2"
                    Grid.Column="3"
                    Margin="4,4,0,0"
                    Content="{x:Static lang:Resources.Label_BaseModel}" />

                <TextBox
                    Grid.Row="3"
                    Grid.Column="0"
                    MinWidth="140"
                    Margin="0,0,4,0"
                    Text="{Binding TagQuery, Mode=TwoWay}" />
                <TextBox
                    Grid.Row="3"
                    Grid.Column="1"
                    MinWidth="140"
                    Margin="4,0,4,0"
                    Text="{Binding UsernameQuery, Mode=TwoWay}" />
                <Button
                    Grid.Row="3"
                    Grid.Column="2"
                    Margin="4,0,4,0"
                    Content="Model types">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel MaxWidth="350" Spacing="8">
                                <Button Command="{Binding ToggleAllModelTypesCommand}" Content="Toggle all" />
                                <ui:ItemsRepeater ItemsSource="{Binding AllModelTypes}">
                                    <ui:ItemsRepeater.Layout>
                                        <ui:FlowLayout
                                            MinColumnSpacing="4"
                                            MinRowSpacing="4"
                                            Orientation="Horizontal" />
                                    </ui:ItemsRepeater.Layout>
                                    <ui:ItemsRepeater.ItemTemplate>
                                        <DataTemplate DataType="{x:Type checkpointManager:BaseModelOptionViewModel}">
                                            <ToggleButton Content="{Binding ModelType}" IsChecked="{Binding IsSelected}" />
                                        </DataTemplate>
                                    </ui:ItemsRepeater.ItemTemplate>
                                </ui:ItemsRepeater>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="3"
                    Margin="4,0,0,0"
                    Content="Base models">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel MaxWidth="350" Spacing="8">
                                <Button Command="{Binding ToggleAllBaseModelsCommand}" Content="Toggle all" />
                                <ui:ItemsRepeater ItemsSource="{Binding AllBaseModels}">
                                    <ui:ItemsRepeater.Layout>
                                        <ui:FlowLayout
                                            MinColumnSpacing="4"
                                            MinRowSpacing="4"
                                            Orientation="Horizontal" />
                                    </ui:ItemsRepeater.Layout>
                                    <ui:ItemsRepeater.ItemTemplate>
                                        <DataTemplate DataType="{x:Type checkpointManager:BaseModelOptionViewModel}">
                                            <ToggleButton Content="{Binding ModelType}" IsChecked="{Binding IsSelected}" />
                                        </DataTemplate>
                                    </ui:ItemsRepeater.ItemTemplate>
                                </ui:ItemsRepeater>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>
        </StackPanel>

        <scroll:BetterScrollViewer
            Name="ImageScrollViewer"
            Grid.Row="1"
            ScrollChanged="ScrollViewer_OnScrollChanged">
            <ItemsRepeater
                HorizontalAlignment="Center"
                ItemTemplate="{StaticResource CivArchiveCardTemplate}"
                ItemsSource="{Binding Results}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinColumnSpacing="8"
                        MinRowSpacing="8"
                        Orientation="Horizontal" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </scroll:BetterScrollViewer>

        <TextBlock
            Grid.RowSpan="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="20"
            IsVisible="{Binding NoResultsFound}"
            Text="{Binding NoResultsText}" />

        <controls:ProgressRing
            Grid.Row="1"
            Width="128"
            Height="128"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsIndeterminate="True"
            IsVisible="{Binding IsLoading}" />
    </Grid>
</controls:UserControlBase>
