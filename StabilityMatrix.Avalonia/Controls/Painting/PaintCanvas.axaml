<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:StabilityMatrix.Avalonia.Controls"
    xmlns:converters="clr-namespace:StabilityMatrix.Avalonia.Converters"
    xmlns:fluentIcons="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
    xmlns:input="clr-namespace:FluentAvalonia.UI.Input;assembly=FluentAvalonia"
    xmlns:mocks="clr-namespace:StabilityMatrix.Avalonia.DesignData"
    xmlns:models="clr-namespace:StabilityMatrix.Avalonia.Models"
    xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:vmControls="clr-namespace:StabilityMatrix.Avalonia.ViewModels.Controls"
    x:DataType="vmControls:PaintCanvasViewModel">
    <Design.PreviewWith>
        <controls:PaintCanvas DataContext="{x:Static mocks:DesignData.PaintCanvasViewModel}" />
    </Design.PreviewWith>

    <Styles.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumBoolConverter" />
    </Styles.Resources>

    <Style Selector="controls|PaintCanvas">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">
                    <Grid.Resources>
                        <input:StandardUICommand
                            x:Key="ClearCanvasCommand"
                            Command="{Binding ClearCanvasCommand}"
                            IconSource="Clear"
                            Label="Clear" />
                        <input:StandardUICommand
                            x:Key="UndoCommand"
                            Command="{Binding UndoCommand}"
                            HotKey="Ctrl+Z"
                            IconSource="Undo"
                            Label="Undo" />
                    </Grid.Resources>

                    <!--  Vertical Tool Palette (Left Side)  -->
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical" Spacing="4">
                            <!--  Brush Tool  -->
                            <ToggleButton
                                Width="36"
                                Height="36"
                                Padding="0"
                                IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.PaintBrush}}"
                                ToolTip.Tip="Brush (B)">
                                <fluentIcons:SymbolIcon FontSize="18" Symbol="PaintBrush" />
                            </ToggleButton>

                            <!--  Eraser Tool  -->
                            <ToggleButton
                                Width="36"
                                Height="36"
                                Padding="0"
                                IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.Eraser}}"
                                ToolTip.Tip="Eraser (E)">
                                <fluentIcons:SymbolIcon FontSize="18" Symbol="Eraser" />
                            </ToggleButton>

                            <Rectangle
                                Height="1"
                                Margin="4,4"
                                HorizontalAlignment="Stretch"
                                Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                            <!--  Rectangle Tool  -->
                            <ToggleButton
                                Width="36"
                                Height="36"
                                Padding="0"
                                IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.Rectangle}}"
                                ToolTip.Tip="Rectangle (R)">
                                <fluentIcons:SymbolIcon FontSize="18" Symbol="Square" />
                            </ToggleButton>

                            <!--  Ellipse Tool  -->
                            <ToggleButton
                                Width="36"
                                Height="36"
                                Padding="0"
                                IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.Ellipse}}"
                                ToolTip.Tip="Ellipse (O)">
                                <fluentIcons:SymbolIcon FontSize="18" Symbol="Circle" />
                            </ToggleButton>

                            <Rectangle
                                Height="1"
                                Margin="4,4"
                                HorizontalAlignment="Stretch"
                                Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                            <!--  Paint Bucket Tool  -->
                            <ToggleButton
                                Width="36"
                                Height="36"
                                Padding="0"
                                IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.PaintBucket}}"
                                ToolTip.Tip="Paint Bucket / Flood Fill (G)">
                                <fluentIcons:SymbolIcon FontSize="18" Symbol="PaintBucket" />
                            </ToggleButton>

                            <Rectangle
                                Height="1"
                                Margin="4,8"
                                HorizontalAlignment="Stretch"
                                Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                            <!--  Stroke Mode Toggle  -->
                            <ToggleButton
                                Width="36"
                                Height="36"
                                Padding="0"
                                IsChecked="{Binding IsShapeStrokeOnly}"
                                ToolTip.Tip="Stroke mode (outline only)">
                                <fluentIcons:SymbolIcon FontSize="18" Symbol="SquareHint" />
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!--  Horizontal Options Bar (Top)  -->
                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,0,8"
                        Padding="8,6"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                            <!--  Color Picker  -->
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="Color" />
                                <ui:ColorPickerButton
                                    Height="28"
                                    VerticalAlignment="Center"
                                    Color="{Binding PaintBrushColor}" />
                            </StackPanel>

                            <Rectangle
                                Grid.Column="1"
                                Width="1"
                                Margin="12,4"
                                VerticalAlignment="Stretch"
                                Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                            <!--  Brush Size  -->
                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="Size" />
                                <Slider
                                    Width="100"
                                    VerticalAlignment="Center"
                                    Maximum="100"
                                    Minimum="1"
                                    ToolTip.Tip="Brush size ([ and ] to adjust)"
                                    Value="{Binding PaintBrushSize}" />
                                <TextBlock
                                    Width="28"
                                    VerticalAlignment="Center"
                                    Text="{Binding PaintBrushSize, StringFormat={}{0:F0}}" />

                                <Rectangle
                                    Width="1"
                                    Margin="6,4"
                                    VerticalAlignment="Stretch"
                                    Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                                <!--  Opacity  -->
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="Opacity" />
                                <Slider
                                    Width="80"
                                    VerticalAlignment="Center"
                                    Maximum="1"
                                    Minimum="0"
                                    ToolTip.Tip="Brush opacity"
                                    Value="{Binding PaintBrushAlpha}" />

                                <Rectangle
                                    Width="1"
                                    Margin="6,4"
                                    VerticalAlignment="Stretch"
                                    Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                                <!--  Feathering (Softness)  -->
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="Softness" />
                                <Slider
                                    Width="80"
                                    VerticalAlignment="Center"
                                    Maximum="1"
                                    Minimum="0"
                                    ToolTip.Tip="Brush softness/feathering (0 = hard edge, 1 = soft edge)"
                                    Value="{Binding PaintBrushFeathering}" />
                            </StackPanel>

                            <!--  Spacer  -->
                            <Panel Grid.Column="3" />

                            <!--  Commands (Right side)  -->
                            <StackPanel
                                Grid.Column="4"
                                Orientation="Horizontal"
                                Spacing="4">
                                <Button
                                    Padding="8,6"
                                    Classes="transparent"
                                    Command="{Binding UndoCommand}"
                                    ToolTip.Tip="Undo (Ctrl+Z)">
                                    <fluentIcons:SymbolIcon FontSize="16" Symbol="ArrowUndo" />
                                </Button>
                                <Button
                                    Padding="8,6"
                                    Classes="transparent"
                                    Command="{Binding RedoCommand}"
                                    ToolTip.Tip="Redo (Ctrl+Y)">
                                    <fluentIcons:SymbolIcon FontSize="16" Symbol="ArrowRedo" />
                                </Button>
                                <Button
                                    Padding="8,6"
                                    Classes="transparent"
                                    Command="{Binding ClearCanvasCommand}"
                                    ToolTip.Tip="Clear canvas">
                                    <fluentIcons:SymbolIcon FontSize="16" Symbol="Delete" />
                                </Button>

                                <Rectangle
                                    Width="1"
                                    Margin="4,4"
                                    VerticalAlignment="Stretch"
                                    Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                                <ToggleButton
                                    Padding="8,6"
                                    Classes="transparent"
                                    IsChecked="{Binding ShowGridOverlay}"
                                    ToolTip.Tip="Toggle Grid Overlay">
                                    <fluentIcons:SymbolIcon FontSize="16" Symbol="Grid" />
                                </ToggleButton>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Canvas Area  -->
                    <ZoomBorder
                        x:Name="PART_ZoomBorder"
                        Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="SlateBlue"
                        ClipToBounds="True"
                        Focusable="True"
                        Stretch="None"
                        ZoomSpeed="1.2">
                        <controls:SkiaCustomCanvas
                            x:Name="PART_MainCanvas"
                            Width="1000"
                            Height="1000"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent" />
                    </ZoomBorder>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
