<controls:UserControlBase
    x:Class="StabilityMatrix.Avalonia.Views.ProgressManagerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:StabilityMatrix.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="clr-namespace:StabilityMatrix.Avalonia.Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mocks="clr-namespace:StabilityMatrix.Avalonia.DesignData"
    xmlns:progress="clr-namespace:StabilityMatrix.Avalonia.ViewModels.Progress"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vmBase="clr-namespace:StabilityMatrix.Avalonia.ViewModels.Base"
    Width="550"
    Height="550"
    d:DataContext="{x:Static mocks:DesignData.ProgressManagerViewModel}"
    d:DesignHeight="550"
    d:DesignWidth="550"
    x:DataType="progress:ProgressManagerViewModel"
    mc:Ignorable="d">
    <TabControl Padding="4" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
        <TabItem Header="{x:Static lang:Resources.Label_InProgress}">
            <Grid RowDefinitions="Auto, *">
                <Button
                    Grid.Row="0"
                    Margin="0,0,8,4"
                    Padding="4"
                    HorizontalAlignment="Right"
                    Classes="transparent"
                    Command="{Binding ClearDownloads}"
                    Content="Clear Finished"
                    IsVisible="{Binding !!ProgressItems.Count}" />

                <ScrollViewer Grid.Row="1" Margin="0,4,0,0">
                    <ItemsControl ItemsSource="{Binding ProgressItems, Mode=OneWay}">
                        <ItemsControl.DataTemplates>

                            <DataTemplate DataType="{x:Type vmBase:PausableProgressItemViewModelBase}">
                                <Border
                                    Margin="4"
                                    Padding="8"
                                    Background="#22000000"
                                    BorderBrush="#33000000"
                                    BorderThickness="2"
                                    CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                        <Grid
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,8,0"
                                            RowDefinitions="Auto, Auto">
                                            <TextBlock
                                                MaxWidth="300"
                                                HorizontalAlignment="Left"
                                                Text="{Binding Name, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />

                                            <!--  non-indeterminate progress  -->
                                            <StackPanel
                                                Grid.Row="1"
                                                IsVisible="{Binding !Progress.IsIndeterminate}"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    MaxWidth="200"
                                                    Margin="0,0"
                                                    Text="{Binding Progress.Text, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="NoWrap" />
                                                <TextBlock Margin="4,0,0,0" IsVisible="{Binding !IsCompleted}">
                                                    <Run Text="{Binding Progress.Value, Mode=OneWay}" /><Run Text="%" />
                                                    <Run Text=" - " />
                                                    <Run Foreground="Lime" Text="{Binding Progress.FormattedDownloadSpeed}" />
                                                </TextBlock>

                                            </StackPanel>

                                            <!--  indeterminate progress  -->
                                            <TextBlock
                                                Grid.Row="1"
                                                MaxWidth="200"
                                                Margin="0,4"
                                                IsVisible="{Binding Progress.IsIndeterminate}"
                                                Text="{Binding Progress.Text, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                        </Grid>


                                        <!--  Buttons  -->
                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                            <ToggleButton
                                                Name="PauseResumeToggleButton"
                                                Classes="transparent-full"
                                                Command="{Binding TogglePauseResumeCommand}"
                                                IsChecked="{Binding IsPaused}"
                                                IsVisible="{Binding CanPauseResume}">
                                                <Panel>
                                                    <ui:SymbolIcon IsVisible="{Binding ElementName=PauseResumeToggleButton, Path=!IsChecked}" Symbol="Pause" />
                                                    <ui:SymbolIcon IsVisible="{Binding ElementName=PauseResumeToggleButton, Path=IsChecked}" Symbol="Play" />
                                                </Panel>
                                            </ToggleButton>

                                            <Button
                                                Classes="transparent-full"
                                                Command="{Binding CancelCommand}"
                                                IsVisible="{Binding CanCancel}">
                                                <ui:SymbolIcon Symbol="Cancel" />
                                            </Button>

                                            <!--  Retry button: only visible when download is in Failed state  -->
                                            <Button
                                                Classes="transparent-full"
                                                Command="{Binding RetryCommand}"
                                                IsVisible="{Binding CanRetry}"
                                                ToolTip.Tip="Retry download">
                                                <ui:SymbolIcon Symbol="Refresh" />
                                            </Button>

                                            <!--  Dismiss button: cleans up sidecar files for failed downloads that won't be retried  -->
                                            <Button
                                                Classes="transparent-full"
                                                Command="{Binding DismissCommand}"
                                                IsVisible="{Binding CanDismiss}"
                                                ToolTip.Tip="Dismiss and clean up">
                                                <ui:SymbolIcon Symbol="Delete" />
                                            </Button>
                                        </StackPanel>

                                        <ProgressBar
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="0,8,0,4"
                                            IsIndeterminate="{Binding Progress.IsIndeterminate}"
                                            Value="{Binding Progress.Value, Mode=OneWay}">
                                            <ProgressBar.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Value" Duration="00:00:00.150">
                                                        <DoubleTransition.Easing>
                                                            <SineEaseInOut />
                                                        </DoubleTransition.Easing>
                                                    </DoubleTransition>
                                                </Transitions>
                                            </ProgressBar.Transitions>
                                        </ProgressBar>
                                    </Grid>
                                </Border>
                            </DataTemplate>

                            <DataTemplate DataType="{x:Type progress:ProgressItemViewModel}">
                                <Border
                                    Margin="4"
                                    Padding="8"
                                    Background="#22000000"
                                    BorderBrush="#33000000"
                                    BorderThickness="2"
                                    CornerRadius="8">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Margin="0,0" Text="{Binding Name, Mode=OneWay}" />

                                            <!--  non-indeterminate progress  -->
                                            <TextBlock
                                                MaxWidth="250"
                                                Margin="0,0"
                                                HorizontalAlignment="Left"
                                                IsVisible="{Binding !Progress.IsIndeterminate}">
                                                <Run Text="{Binding Progress.Text, Mode=OneWay}" />
                                                <Run Text="{Binding Progress.Value, Mode=OneWay}" /><Run Text="%" />
                                            </TextBlock>

                                            <!--  indeterminate progress  -->
                                            <TextBlock
                                                MaxWidth="250"
                                                Margin="0,4"
                                                HorizontalAlignment="Left"
                                                IsVisible="{Binding Progress.IsIndeterminate}"
                                                Text="{Binding Progress.Text, Mode=OneWay}" />
                                        </StackPanel>

                                        <ProgressBar
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="0,8,0,4"
                                            IsIndeterminate="{Binding Progress.IsIndeterminate}"
                                            Value="{Binding Progress.Value, Mode=OneWay}">
                                            <ProgressBar.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Value" Duration="00:00:00.150">
                                                        <DoubleTransition.Easing>
                                                            <SineEaseInOut />
                                                        </DoubleTransition.Easing>
                                                    </DoubleTransition>
                                                </Transitions>
                                            </ProgressBar.Transitions>
                                        </ProgressBar>
                                    </Grid>
                                </Border>
                            </DataTemplate>

                            <DataTemplate DataType="{x:Type progress:PackageInstallProgressItemViewModel}">
                                <Border
                                    Margin="4"
                                    Padding="8"
                                    Background="#22000000"
                                    BorderBrush="#33000000"
                                    BorderThickness="2"
                                    CornerRadius="8">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock
                                                MaxWidth="300"
                                                Margin="0,0"
                                                HorizontalAlignment="Left"
                                                Text="{Binding Progress.Text, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />

                                            <!--  non-indeterminate progress  -->
                                            <TextBlock
                                                MaxWidth="300"
                                                Margin="0,4"
                                                HorizontalAlignment="Left"
                                                IsVisible="{Binding !Progress.IsIndeterminate}">
                                                <Run Text="{Binding Progress.Description, Mode=OneWay}" />
                                                <Run Text="{Binding Progress.Value, Mode=OneWay}" /><Run Text="%" />
                                            </TextBlock>

                                            <!--  indeterminate progress  -->
                                            <TextBlock
                                                MinWidth="300"
                                                MaxWidth="300"
                                                Margin="0,4"
                                                HorizontalAlignment="Left"
                                                IsVisible="{Binding Progress.IsIndeterminate}"
                                                Text="{Binding Progress.Description, Mode=OneWay}" />
                                        </StackPanel>


                                        <!--  Buttons  -->
                                        <Button
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="8,0"
                                            Classes="transparent-full"
                                            Command="{Binding ShowProgressDialog}"
                                            ToolTip.Tip="Show Progress Dialog">
                                            <ui:SymbolIcon Symbol="Open" />
                                        </Button>

                                        <ProgressBar
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="0,8,0,4"
                                            IsIndeterminate="{Binding Progress.IsIndeterminate}"
                                            Value="{Binding Progress.Value, Mode=OneWay}">
                                            <ProgressBar.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Value" Duration="00:00:00.150">
                                                        <DoubleTransition.Easing>
                                                            <SineEaseInOut />
                                                        </DoubleTransition.Easing>
                                                    </DoubleTransition>
                                                </Transitions>
                                            </ProgressBar.Transitions>
                                        </ProgressBar>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.DataTemplates>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <TabItem Header="{x:Static lang:Resources.Label_Notifications}">
            <Grid RowDefinitions="Auto, *">
                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,12,4"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="2">
                    <Button
                        Classes="transparent-full"
                        Command="{Binding MarkAllNotificationsReadCommand}"
                        IsVisible="{Binding !!NotificationItems.Count}"
                        ToolTip.Tip="{x:Static lang:Resources.Action_MarkAllRead}">
                        <ui:SymbolIcon Symbol="Read" />
                    </Button>
                    <Button
                        Classes="transparent-full"
                        Command="{Binding ClearNotificationsCommand}"
                        IsVisible="{Binding !!NotificationItems.Count}"
                        ToolTip.Tip="{x:Static lang:Resources.Action_ClearAll}">
                        <ui:SymbolIcon Symbol="Delete" />
                    </Button>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,4,0,0">
                    <ItemsControl ItemsSource="{Binding NotificationItems, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type progress:NotificationItemViewModel}">
                                <Border
                                    Margin="4"
                                    Padding="8"
                                    Background="#22000000"
                                    BorderBrush="#33000000"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Opacity="{Binding ReadOpacity}">
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                        <Ellipse
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Width="10"
                                            Height="10"
                                            Margin="0,6,8,0"
                                            VerticalAlignment="Top"
                                            Fill="{Binding SeverityBrush}"
                                            IsVisible="{Binding IsUnreadIndicatorVisible}" />

                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                Text="{Binding Title, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                IsVisible="{Binding IsPreviewBodyVisible}"
                                                MaxLines="2"
                                                Text="{Binding Body, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Text="{Binding FormattedTimestamp, Mode=OneWay}" />
                                            <Button
                                                Classes="transparent-full"
                                                Command="{Binding ToggleDetailsCommand}"
                                                ToolTip.Tip="{x:Static lang:Resources.Action_ToggleDetails}">
                                                <ui:SymbolIcon Symbol="ChevronDown" />
                                            </Button>
                                            <Button
                                                Classes="transparent-full"
                                                Command="{Binding DismissCommand}"
                                                ToolTip.Tip="{x:Static lang:Resources.Action_Dismiss}">
                                                <ui:SymbolIcon Symbol="Delete" />
                                            </Button>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Margin="0,8,0,0"
                                            IsVisible="{Binding IsExpanded}"
                                            Spacing="6">
                                            <TextBlock
                                                IsVisible="{Binding HasBody}"
                                                Text="{Binding Body, Mode=OneWay}"
                                                TextWrapping="Wrap" />
                                            <Button
                                                Classes="accent"
                                                Command="{Binding InvokeActionCommand}"
                                                Content="{Binding ActionLabel}"
                                                IsVisible="{Binding HasAction}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </TabItem>
    </TabControl>
</controls:UserControlBase>
