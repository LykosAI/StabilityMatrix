<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
    xmlns:controls="clr-namespace:StabilityMatrix.Avalonia.Controls"
    xmlns:markupExtensions="clr-namespace:StabilityMatrix.Avalonia.MarkupExtensions"
    xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia">
    <!--  Context menu for editors  -->
    <ui:FAMenuFlyout x:Key="EditorContextFlyout">
        <ui:MenuFlyoutItem
            Command="{x:Static controls:EditorCommands.PasteCommand}"
            CommandParameter="{Binding $parent[avaloniaEdit:TextEditor]}"
            HotKey="{markupExtensions:PlatformGesture Ctrl+V}"
            IconSource="Paste"
            Text="Paste" />
        <ui:MenuFlyoutItem
            Command="{x:Static controls:EditorCommands.CopyCommand}"
            CommandParameter="{Binding $parent[avaloniaEdit:TextEditor]}"
            HotKey="{markupExtensions:PlatformGesture Ctrl+C}"
            IconSource="Copy"
            Text="Copy" />
        <ui:MenuFlyoutItem
            Command="{x:Static controls:EditorCommands.CutCommand}"
            CommandParameter="{Binding $parent[avaloniaEdit:TextEditor]}"
            HotKey="{markupExtensions:PlatformGesture Ctrl+X}"
            IconSource="Cut"
            Text="Cut" />
        <ui:MenuFlyoutItem
            Command="{x:Static controls:EditorCommands.UndoCommand}"
            CommandParameter="{Binding $parent[avaloniaEdit:TextEditor]}"
            HotKey="{markupExtensions:PlatformGesture Ctrl+Z}"
            IconSource="Undo"
            Text="Undo" />
        <ui:MenuFlyoutItem
            Command="{x:Static controls:EditorCommands.RedoCommand}"
            CommandParameter="{Binding $parent[avaloniaEdit:TextEditor]}"
            HotKey="{markupExtensions:PlatformGesture Ctrl+Y}"
            IconSource="Redo"
            Text="Redo" />
    </ui:FAMenuFlyout>
</ResourceDictionary>
