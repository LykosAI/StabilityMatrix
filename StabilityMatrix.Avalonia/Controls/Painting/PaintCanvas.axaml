<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:StabilityMatrix.Avalonia.Controls"
    xmlns:converters="clr-namespace:StabilityMatrix.Avalonia.Converters"
    xmlns:faIcons="https://github.com/projektanker/icons.avalonia"
    xmlns:fluentIcons="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
    xmlns:input="clr-namespace:FluentAvalonia.UI.Input;assembly=FluentAvalonia"
    xmlns:mocks="clr-namespace:StabilityMatrix.Avalonia.DesignData"
    xmlns:models="clr-namespace:StabilityMatrix.Avalonia.Models"
    xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:vmControls="clr-namespace:StabilityMatrix.Avalonia.ViewModels.Controls"
    x:DataType="vmControls:PaintCanvasViewModel">
    <Design.PreviewWith>
        <controls:PaintCanvas DataContext="{x:Static mocks:DesignData.PaintCanvasViewModel}" />
    </Design.PreviewWith>

    <Styles.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumBoolConverter" />
    </Styles.Resources>

    <Style Selector="controls|PaintCanvas">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid RowDefinitions="Auto,Auto">
                    <Grid.Resources>
                        <input:StandardUICommand
                            x:Key="ClearCanvasCommand"
                            Command="{Binding ClearCanvasCommand}"
                            IconSource="Clear"
                            Label="Clear" />
                        <input:StandardUICommand
                            x:Key="UndoCommand"
                            Command="{Binding UndoCommand}"
                            HotKey="Ctrl+Z"
                            IconSource="Undo"
                            Label="Undo" />
                    </Grid.Resources>
                    <Grid.Styles>
                        <!--  Change cursor to crosshair when mouse is over the canvas  -->
                        <!--<Style Selector="controls|SkiaCustomCanvas:pointerover">
                            <Setter Property="Cursor" Value="Cross"/>
                        </Style>
                        <Style Selector="controls|SkiaCustomCanvas:pointerleave">
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Style>-->
                    </Grid.Styles>

                    <!--  Top bar  -->
                    <StackPanel Orientation="Horizontal" Spacing="6">

                        <!--  Tools  -->
                        <controls:Card Padding="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ToggleButton IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.PaintBrush}}" ToolTip.Tip="Brush (B)">
                                    <faIcons:Icon FontSize="18" Value="fa-solid fa-paintbrush" />
                                </ToggleButton>
                                <ToggleButton IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.Eraser}}" ToolTip.Tip="Eraser (E)">
                                    <faIcons:Icon FontSize="18" Value="fa-solid fa-eraser" />
                                </ToggleButton>
                                <ToggleButton IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.Rectangle}}" ToolTip.Tip="Rectangle (R)">
                                    <faIcons:Icon FontSize="18" Value="fa-regular fa-square" />
                                </ToggleButton>
                                <ToggleButton IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.Ellipse}}" ToolTip.Tip="Ellipse (O)">
                                    <faIcons:Icon FontSize="18" Value="fa-regular fa-circle" />
                                </ToggleButton>
                                <ToggleButton IsChecked="{Binding SelectedTool, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:PaintCanvasTool.PaintBucket}}" ToolTip.Tip="Paint Bucket / Flood Fill (G)">
                                    <faIcons:Icon FontSize="18" Value="fa-solid fa-fill-drip" />
                                </ToggleButton>
                                <GridSplitter Margin="4,12" BorderThickness="1" />
                                <CheckBox
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding IsShapeStrokeOnly}"
                                    ToolTip.Tip="Draw shape outlines only (stroke mode)">
                                    <TextBlock Text="Stroke" />
                                </CheckBox>
                            </StackPanel>
                        </controls:Card>

                        <GridSplitter Margin="0,16" BorderThickness="1" />

                        <ui:ColorPickerButton VerticalAlignment="Center" Color="{Binding PaintBrushColor}" />
                        <Label
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Content="Pressure:" />
                        <Label
                            Margin="-4,0,0,0"
                            VerticalAlignment="Center"
                            Content="{Binding CurrentPenPressure}" />

                        <!--  Brush Size Slider  -->
                        <StackPanel
                            Margin="8,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <TextBlock VerticalAlignment="Center" Text="Size:" />
                            <Slider
                                Width="80"
                                Maximum="100"
                                Minimum="1"
                                ToolTip.Tip="Brush size ([ and ] to adjust)"
                                Value="{Binding PaintBrushSize}" />
                            <TextBlock
                                Width="24"
                                VerticalAlignment="Center"
                                Text="{Binding PaintBrushSize, StringFormat={}{0:F0}}" />
                        </StackPanel>

                        <ui:CommandBar Margin="0,4" HorizontalAlignment="Right">
                            <ui:CommandBar.PrimaryCommands>
                                <!--  Opacity  -->
                                <ui:CommandBarButton>
                                    <ui:CommandBarButton.IconSource>
                                        <fluentIcons:SymbolIconSource FontSize="12" Symbol="CircleHalfFill" />
                                    </ui:CommandBarButton.IconSource>
                                    <ui:CommandBarButton.Flyout>
                                        <Flyout>
                                            <StackPanel>
                                                <Label Content="Brush Opacity" />
                                                <Slider
                                                    MinWidth="200"
                                                    IsSnapToTickEnabled="True"
                                                    Maximum="1"
                                                    Minimum="0"
                                                    SmallChange="0.01"
                                                    TickFrequency="0.01"
                                                    Value="{Binding PaintBrushAlpha}" />
                                            </StackPanel>
                                        </Flyout>
                                    </ui:CommandBarButton.Flyout>
                                </ui:CommandBarButton>

                                <ui:CommandBarButton
                                    Command="{Binding UndoCommand}"
                                    IconSource="Undo"
                                    ToolTip.Tip="Undo (Ctrl+Z)" />
                                <ui:CommandBarButton
                                    Command="{Binding RedoCommand}"
                                    IconSource="Redo"
                                    ToolTip.Tip="Redo (Ctrl+Y)" />
                                <ui:CommandBarButton Command="{StaticResource ClearCanvasCommand}" />
                                <ui:CommandBarToggleButton IsChecked="{Binding ShowGridOverlay}" ToolTip.Tip="Toggle Grid Overlay">
                                    <ui:CommandBarToggleButton.IconSource>
                                        <fluentIcons:SymbolIconSource Symbol="Grid" />
                                    </ui:CommandBarToggleButton.IconSource>
                                </ui:CommandBarToggleButton>

                            </ui:CommandBar.PrimaryCommands>

                            <!--<ui:CommandBar.SecondaryCommands>
                                <ui:CommandBarButton Command="{StaticResource UndoCommand}" />
                                <ui:CommandBarButton Command="{StaticResource ClearCanvasCommand}" />
                            </ui:CommandBar.SecondaryCommands>-->
                        </ui:CommandBar>
                    </StackPanel>

                    <ZoomBorder
                        x:Name="PART_ZoomBorder"
                        Grid.Row="1"
                        Margin="0,2,0,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="SlateBlue"
                        ClipToBounds="True"
                        Focusable="True"
                        Stretch="None"
                        ZoomSpeed="1.2">
                        <controls:SkiaCustomCanvas
                            x:Name="PART_MainCanvas"
                            Width="1000"
                            Height="1000"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent" />
                    </ZoomBorder>

                </Grid>
            </ControlTemplate>
        </Setter>


    </Style>
</Styles>
