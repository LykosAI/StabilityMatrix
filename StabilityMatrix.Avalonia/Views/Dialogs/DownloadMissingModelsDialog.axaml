<controls:UserControlBase
    x:Class="StabilityMatrix.Avalonia.Views.Dialogs.DownloadMissingModelsDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:StabilityMatrix.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vmDialogs="clr-namespace:StabilityMatrix.Avalonia.ViewModels.Dialogs"
    d:DesignHeight="400"
    d:DesignWidth="550"
    x:DataType="vmDialogs:DownloadMissingModelsViewModel"
    mc:Ignorable="d">

    <Grid Margin="4" RowDefinitions="Auto, Auto, *, Auto">

        <!--  Description  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,16"
            Opacity="0.8"
            Text="{Binding Description}"
            TextWrapping="Wrap" />

        <!--  Selection Controls  -->
        <Grid
            Grid.Row="1"
            Margin="0,0,0,12"
            ColumnDefinitions="Auto, Auto, *, Auto">
            <Button
                Grid.Column="0"
                Margin="0,0,8,0"
                Padding="12,6"
                Classes="accent"
                Command="{Binding SelectAllCommand}"
                Content="Select All" />
            <Button
                Grid.Column="1"
                Padding="12,6"
                Command="{Binding DeselectAllCommand}"
                Content="Deselect All" />

            <!--  Selected count and size  -->
            <StackPanel
                Grid.Column="3"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock VerticalAlignment="Center" Opacity="0.7">
                    <Run Text="{Binding SelectedCount}" />
                    <Run Text="selected" />
                </TextBlock>
                <Border
                    Padding="10,4"
                    Background="{DynamicResource SystemAccentColor}"
                    CornerRadius="10"
                    IsVisible="{Binding SelectedCount}">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="{Binding TotalSelectedSizeText}" />
                </Border>
            </StackPanel>
        </Grid>

        <!--  Models List  -->
        <ScrollViewer
            Grid.Row="2"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Models}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vmDialogs:DownloadableModelItemViewModel">
                        <Border
                            Margin="0,0,0,8"
                            Padding="12"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <!--  Checkbox  -->
                                <CheckBox
                                    Grid.Column="0"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding IsSelected}" />

                                <!--  Model Info  -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding DisplayName}" />
                                        <!--  Type Badge  -->
                                        <Border
                                            Padding="6,2"
                                            Background="{DynamicResource SystemAccentColor}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding TypeBadge}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="{Binding FileName}" />
                                </StackPanel>

                                <!--  File Size  -->
                                <Border
                                    Grid.Column="2"
                                    Padding="8,4"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SystemAccentColor}"
                                    CornerRadius="10">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding FileSizeText}"
                                        TextAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  Loading Indicator  -->
        <Border
            Grid.Row="3"
            Margin="0,8,0,0"
            Padding="12,8"
            HorizontalAlignment="Center"
            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="6"
            IsVisible="{Binding IsLoadingSizes}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ui:ProgressRing
                    Width="16"
                    Height="16"
                    IsIndeterminate="True" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Opacity="0.8"
                    Text="Calculating file sizes..." />
            </StackPanel>
        </Border>
    </Grid>
</controls:UserControlBase>
